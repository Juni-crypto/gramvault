# ============================================================
# InstaIntel Configuration
# ============================================================
# Send Instagram URLs to the Telegram bot → auto-downloads,
# analyzes (OCR/Vision/AI), and builds a searchable knowledge base.

# --- Vision / OCR ---
# auto | gemini | claude | tesseract
VISION_PROVIDER=gemini

# --- Anthropic (entity extraction + RAG chat) ---
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# --- Gemini (vision + video analysis) ---
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_VIDEO_MODEL=gemini-2.5-flash

# --- Telegram Bot ---
# Token: message @BotFather → /newbot
# User ID: message @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWED_USERS=your_telegram_user_id

# --- Storage ---
DATA_DIR=./data
MEDIA_DIR=./data/media

# --- Processing ---
REEL_KEYFRAME_INTERVAL=3
EMBEDDING_MODEL=all-MiniLM-L6-v2
LOG_LEVEL=INFO
